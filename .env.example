# Copy this file to .env and fill in your values

# Required: Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth credentials (only needed for --live mode)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Obsidian vault path (expand ~ automatically)
# Mac iCloud example: ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/MyVault
OBSIDIAN_VAULT_PATH=~/Documents/ObsidianVault

# Pipeline settings
USE_MOCK_DATA=true       # Set to false to use real Gmail/Calendar
MAX_EMAILS=20            # Max emails to fetch per run
CALENDAR_DAYS_AHEAD=3    # Days of calendar to include
